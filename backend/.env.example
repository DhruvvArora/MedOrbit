# MedOrbit Backend Environment Variables
# Copy this file to .env and update values

# Database
DATABASE_URL=sqlite:///./medorbit.db

# JWT Auth
SECRET_KEY=medorbit-hackathon-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# App
APP_NAME=MedOrbit
DEBUG=true

# Auth bypass (development only)
# Set to true ONLY for backend-only local debugging.
# When enabled, all protected routes resolve as the demo doctor user.
# Patient routes will return 403 in this mode.
# For full-flow testing, use seeded demo accounts with real login.
# Default: false (real auth required)
SKIP_AUTH=false
